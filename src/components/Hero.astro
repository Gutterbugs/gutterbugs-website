---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "Your Trusted Exterior Cleaning Experts",
  subtitle = "Professional gutter clearing, roof cleaning & pressure washing. Family-run, fully insured, 3000+ homes cleaned."
} = Astro.props;
---

<section class="relative bg-white pt-28 pb-20 overflow-hidden">
  <!-- Subtle accent -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-sky-50 to-transparent pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-sky-500/10 border border-sky-500/30 rounded-full px-5 py-2 mb-8">
        <span class="w-2 h-2 bg-sky-400 rounded-full"></span>
        <span class="text-sky-400 text-sm font-medium">Serving Your Area</span>
      </div>

      <!-- H1 -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-gray-900 mb-6 leading-tight font-['Poppins']">
        {title}
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-gray-600 mb-10 max-w-2xl mx-auto leading-relaxed">
        {subtitle}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a
          href="/contact"
          class="inline-flex items-center justify-center bg-sky-500 hover:bg-sky-600 text-white px-8 py-4 rounded-full font-semibold text-lg transition-all duration-200 shadow-xl shadow-sky-500/30 hover:shadow-sky-500/50 hover:-translate-y-0.5"
        >
          Get Free Quote →
        </a>
        <a
          href="tel:07904621160"
          class="inline-flex items-center justify-center border-2 border-gray-300 text-gray-900 hover:bg-sky-50 hover:border-sky-300 px-8 py-4 rounded-full font-semibold text-lg transition-all duration-200"
        >
          📞 Call Now
        </a>
      </div>

      <!-- Trust Badges -->
      <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-8">
        {[
          { icon: '✓', label: 'Fully Insured' },
          { icon: '★', label: '5-Star Rated' },
          { icon: '⚡', label: 'Same-Day Quotes' },
          { icon: '🏠', label: 'Family Business' },
        ].map(badge => (
          <div class="flex items-center gap-2 text-gray-600">
            <span class="text-sky-400 font-bold">{badge.icon}</span>
            <span class="text-sm font-medium">{badge.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
