---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';
import reviewData from '../data/reviews.json';

const { totalReviews, averageRating, ratingBreakdown, reviews } = reviewData;

// Format a date like "March 2026"
function formatDate(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
}

// Format relative time like "2 months ago"
function timeAgo(iso: string): string {
  const now = new Date();
  const then = new Date(iso);
  const diffMs = now.getTime() - then.getTime();
  const days = Math.floor(diffMs / (1000 * 60 * 60 * 24));
  if (days < 1) return 'Today';
  if (days === 1) return 'Yesterday';
  if (days < 7) return `${days} days ago`;
  if (days < 30) return `${Math.floor(days / 7)} week${Math.floor(days / 7) > 1 ? 's' : ''} ago`;
  if (days < 365) return `${Math.floor(days / 30)} month${Math.floor(days / 30) > 1 ? 's' : ''} ago`;
  return `${Math.floor(days / 365)} year${Math.floor(days / 365) > 1 ? 's' : ''} ago`;
}
---

<Layout
  title="Customer Reviews | Gutterbugs — 92 Five-Star Google Reviews"
  description={`Read ${totalReviews} genuine Google reviews from Gutterbugs customers. ${averageRating}/5 average rating. Professional gutter clearing, roof cleaning & exterior cleaning across Hertfordshire.`}
>
  <!-- Hero -->
  <section class="bg-white pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-sky-900/20 to-transparent pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <div class="inline-flex items-center gap-2 bg-yellow-400/10 border border-yellow-400/30 rounded-full px-4 py-1.5 mb-6">
        <span class="text-yellow-500 text-sm font-medium">★ {averageRating}/5 on Google</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6" style="font-family: 'Poppins', sans-serif;">
        Customer Reviews
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Don't just take our word for it — here's what <strong>{totalReviews} real customers</strong> have to say about Gutterbugs.
      </p>
    </div>
  </section>

  <!-- Summary Stats -->
  <section class="pb-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gray-50 rounded-2xl p-8 border border-gray-200">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
          <!-- Left: Big rating -->
          <div class="text-center md:text-left">
            <div class="flex items-baseline justify-center md:justify-start gap-2 mb-2">
              <span class="text-5xl font-bold text-gray-900" style="font-family: 'Poppins', sans-serif;">{averageRating}</span>
              <span class="text-2xl text-gray-400">/5</span>
            </div>
            <div class="flex gap-1 justify-center md:justify-start mb-2">
              {Array.from({ length: 5 }).map((_, i) => (
                <span class={`text-2xl ${i < Math.round(averageRating) ? 'text-yellow-400' : 'text-gray-300'}`}>★</span>
              ))}
            </div>
            <p class="text-gray-500 text-sm">Based on {totalReviews} Google reviews</p>
          </div>

          <!-- Right: Rating breakdown bars -->
          <div class="space-y-2">
            {ratingBreakdown.map((rb: { stars: number; count: number }) => {
              const pct = totalReviews > 0 ? Math.round((rb.count / totalReviews) * 100) : 0;
              return (
                <div class="flex items-center gap-3">
                  <span class="text-sm text-gray-600 w-12 text-right">{rb.stars} star</span>
                  <div class="flex-1 h-3 bg-gray-200 rounded-full overflow-hidden">
                    <div
                      class="h-full bg-yellow-400 rounded-full transition-all duration-500"
                      style={`width: ${pct}%`}
                    />
                  </div>
                  <span class="text-sm text-gray-500 w-10">{rb.count}</span>
                </div>
              );
            })}
          </div>
        </div>

        <!-- Google link -->
        <div class="mt-6 pt-6 border-t border-gray-200 text-center">
          <a
            href="https://www.google.com/maps/place/Gutterbugs+Exterior+Cleaning/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sky-600 hover:text-sky-700 text-sm font-medium transition-colors"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            View us on Google
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews Grid -->
  <section class="pb-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="reviews-grid">
        {reviews.map((review: { id: string; author: string; rating: number; text: string; time: string; reply: { text: string; time: string } | null }, index: number) => (
          <div
            class={`bg-gray-50 rounded-2xl p-6 border border-gray-200 hover:border-sky-500/20 transition-all duration-300 hover:shadow-lg hover:shadow-sky-500/5 flex flex-col ${index >= 12 ? 'hidden review-extra' : ''}`}
          >
            <!-- Stars + Date -->
            <div class="flex items-center justify-between mb-4">
              <div class="flex gap-0.5">
                {Array.from({ length: review.rating }).map(() => (
                  <span class="text-yellow-400 text-lg">★</span>
                ))}
                {Array.from({ length: 5 - review.rating }).map(() => (
                  <span class="text-gray-300 text-lg">★</span>
                ))}
              </div>
              <span class="text-gray-400 text-xs">{timeAgo(review.time)}</span>
            </div>

            <!-- Review Text -->
            {review.text ? (
              <p class="text-gray-600 text-sm leading-relaxed mb-5 flex-grow">
                "{review.text}"
              </p>
            ) : (
              <p class="text-gray-400 text-sm italic mb-5 flex-grow">
                (No written review — {review.rating}-star rating)
              </p>
            )}

            <!-- Owner Reply -->
            {review.reply && (
              <div class="bg-sky-50 rounded-xl p-4 mb-5 border border-sky-100">
                <p class="text-xs font-semibold text-sky-700 mb-1">Reply from Gutterbugs</p>
                <p class="text-gray-600 text-xs leading-relaxed">{review.reply.text}</p>
              </div>
            )}

            <!-- Author -->
            <div class="flex items-center gap-3 mt-auto">
              <div class="w-9 h-9 bg-sky-500/20 rounded-full flex items-center justify-center">
                <span class="text-sky-400 font-bold text-sm">{review.author.charAt(0).toUpperCase()}</span>
              </div>
              <div>
                <p class="text-gray-900 font-semibold text-sm">{review.author}</p>
                <p class="text-gray-500 text-xs">{formatDate(review.time)}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      {reviews.length > 12 && (
        <div class="text-center mt-10" id="show-more-container">
          <button
            id="show-more-btn"
            class="inline-flex items-center gap-2 bg-sky-500 hover:bg-sky-600 text-white px-8 py-3 rounded-full text-sm font-semibold transition-all duration-200 shadow-lg shadow-sky-500/25"
          >
            Show All {totalReviews} Reviews
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
        </div>
      )}
    </div>
  </section>

  <CTASection />
</Layout>

<!-- Schema.org Review aggregate -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Gutterbugs Exterior Cleaning",
  "url": "https://gutterbugs.co.uk",
  "telephone": "07904621160",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": averageRating,
    "reviewCount": totalReviews,
    "bestRating": 5,
    "worstRating": 1
  },
  "review": reviews.slice(0, 10).map((r: { author: string; rating: number; text: string; time: string }) => ({
    "@type": "Review",
    "author": { "@type": "Person", "name": r.author },
    "datePublished": r.time.split('T')[0],
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": r.rating,
      "bestRating": 5,
    },
    "reviewBody": r.text || undefined,
  })),
})} />

<script is:inline>
  // Show more reviews toggle
  const btn = document.getElementById('show-more-btn');
  const container = document.getElementById('show-more-container');
  btn?.addEventListener('click', () => {
    document.querySelectorAll('.review-extra').forEach(el => el.classList.remove('hidden'));
    container?.remove();
  });
</script>
