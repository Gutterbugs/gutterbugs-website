---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CTASection from '../components/CTASection.astro';

const services = [
  {
    icon: '🏠',
    title: 'Gutter Clearing',
    description: 'Professional gutter cleaning and clearing service. We remove all debris, test for leaks and ensure your gutters flow freely.',
    href: '/gutter-clearing',
    price: '£65',
  },
  {
    icon: '🏡',
    title: 'Roof Cleaning',
    description: "Expert moss removal and biocide treatment to protect your roof. Low-pressure soft washing that won't damage your tiles.",
    href: '/roof-cleaning',
    price: '£400',
  },
  {
    icon: '💧',
    title: 'Pressure Washing',
    description: 'High-pressure cleaning for driveways, patios, and paths. Transform your exterior surfaces back to their best.',
    href: '/pressure-washing',
    price: '£100',
  },
  {
    icon: '🪟',
    title: 'Soffit & Fascia Washing',
    description: 'Deep clean your soffits and fascias to remove algae, mould and grime. Protect and restore your roofline.',
    href: '/soffit-fascia-washing',
    price: '£80',
  },
  {
    icon: '🏗️',
    title: 'Conservatory Cleaning',
    description: 'Complete conservatory cleaning including roof panels, frames and gutters. Let the light back in.',
    href: '/conservatory-cleaning',
    price: '£120',
  },
  {
    icon: '☀️',
    title: 'Solar Panel Cleaning',
    description: 'Specialist solar panel cleaning to maximise your energy output. Dirty panels lose up to 25% efficiency.',
    href: '/solar-panel-cleaning',
    price: '£80',
  },
];

import reviewData from '../data/reviews.json';

// Get the top 6 reviews for the homepage
const topReviews = reviewData.reviews.slice(0, 6);
const rating = reviewData.averageRating;
const totalReviews = reviewData.totalReviews;

---

<Layout
  title="Gutterbugs | Hertfordshire's Trusted Exterior Cleaning Experts"
  description="Professional gutter clearing, roof cleaning & pressure washing across Hertfordshire. Family-run, fully insured, 3000+ homes cleaned. Get a free quote today."
>
  <Hero />
  <TrustBar />

  <!-- Services Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 bg-sky-500/10 border border-sky-500/30 rounded-full px-4 py-1.5 mb-5">
          <span class="text-sky-400 text-sm font-medium">What We Do</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4" style="font-family: 'Poppins', sans-serif;">
          Our Cleaning Services
        </h2>
        <p class="text-gray-500 max-w-2xl mx-auto">
          From gutter clearing to roof cleaning, we provide a comprehensive range of professional exterior cleaning services.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(service => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>

    <!-- Google Reviews (Live from GMB) -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 bg-sky-500/10 border border-sky-500/30 rounded-full px-4 py-1.5 mb-5">
          <span class="text-sky-500 text-sm font-medium">Google Reviews</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4" style="font-family: 'Poppins', sans-serif;">
          What Our Customers Say
        </h2>
        <div class="flex items-center justify-center gap-2">
          <div class="flex gap-0.5">
            {[1,2,3,4,5].map(() => <span class="text-yellow-400 text-xl">★</span>)}
          </div>
          <span class="text-gray-700 text-sm ml-1 font-medium">{rating} · {totalReviews} reviews on Google</span>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {topReviews.map(r => {
          const now = new Date();
          const then = new Date(r.time);
          const diffMs = now.getTime() - then.getTime();
          const days = Math.floor(diffMs / (1000 * 60 * 60 * 24));
          
          let relativeTime = '';
          if (days < 1) relativeTime = 'Today';
          else if (days === 1) relativeTime = 'Yesterday';
          else if (days < 7) relativeTime = `${days} days ago`;
          else if (days < 30) relativeTime = `${Math.floor(days / 7)} week${Math.floor(days / 7) > 1 ? 's' : ''} ago`;
          else if (days < 365) relativeTime = `${Math.floor(days / 30)} month${Math.floor(days / 30) > 1 ? 's' : ''} ago`;
          else relativeTime = `${Math.floor(days / 365)} year${Math.floor(days / 365) > 1 ? 's' : ''} ago`;

          return (
            <div class="bg-gray-50 border border-gray-100 rounded-2xl p-6 hover:shadow-md transition-shadow duration-200 block">
              <div class="flex items-center justify-between mb-4">
                <div class="flex gap-0.5">
                  {Array.from({ length: r.rating }).map(() => <span class="text-yellow-400 text-sm">★</span>)}
                  {Array.from({ length: 5 - r.rating }).map(() => <span class="text-gray-300 text-sm">★</span>)}
                </div>
                <span class="text-gray-400 text-xs">{relativeTime}</span>
              </div>
              
              <p class="text-gray-700 text-sm leading-relaxed mb-5 flex-grow line-clamp-4">"{r.text}"</p>
              
              <div class="flex items-center gap-3 mt-auto border-t border-gray-100 pt-4">
                {r.profilePhoto ? (
                  <img src={r.profilePhoto} alt={r.author} class="w-8 h-8 rounded-full" loading="lazy" />
                ) : (
                  <div class="w-8 h-8 rounded-full bg-sky-100 flex items-center justify-center text-sky-600 font-bold text-xs">
                    {r.author.charAt(0)}
                  </div>
                )}
                <div>
                  <p class="text-gray-900 font-semibold text-sm leading-none">{r.author}</p>
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <div class="text-center mt-10">
        <a
          href="/reviews"
          class="inline-flex items-center gap-2 text-sky-600 hover:text-sky-700 font-medium text-sm transition-colors"
        >
          Read all {totalReviews} verified reviews →
        </a>
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
