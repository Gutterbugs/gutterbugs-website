---
import Layout from './Layout.astro';
import CTASection from '../components/CTASection.astro';
import TrustStack from '../components/TrustStack.astro';

interface Props {
  title: string;
  description: string;
  heroTitle: string;
  heroSubtitle: string;
  canonicalURL?: string;
  heroImage?: string;
  heroImageAlt?: string;
}

const { title, description, heroTitle, heroSubtitle, canonicalURL, heroImage, heroImageAlt } = Astro.props;
---

<Layout title={title} description={description} canonicalURL={canonicalURL}>
  <!-- Hero -->
  <section class="bg-white pt-32 pb-20 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-sky-900/20 to-transparent pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class={heroImage ? "grid grid-cols-1 lg:grid-cols-2 gap-12 items-center" : ""}>
        <div class={heroImage ? "" : "max-w-3xl"}>
          <div class="inline-flex items-center gap-2 bg-sky-500/10 border border-sky-500/30 rounded-full px-4 py-1.5 mb-6">
            <span class="w-2 h-2 bg-sky-400 rounded-full"></span>
            <span class="text-sky-400 text-sm font-medium">Professional Service</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 leading-tight" style="font-family: 'Poppins', sans-serif;">
            {heroTitle}
          </h1>
          <p class="text-xl text-gray-600 mb-8 leading-relaxed">
            {heroSubtitle}
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a href="/contact" class="inline-flex items-center justify-center bg-sky-500 hover:bg-sky-600 text-white px-8 py-4 rounded-full font-semibold text-lg transition-all duration-200 shadow-lg shadow-sky-500/25">
              Get Free Quote →
            </a>
            <a href="tel:07904621160" class="inline-flex items-center justify-center border-2 border-white/30 text-gray-900 hover:bg-white hover:text-gray-900 px-8 py-4 rounded-full font-semibold text-lg transition-all duration-200">
              📞 07904621160
            </a>
          </div>
          <!-- Trust Stack — added 2026-04-28 per landing-page audit (was missing on all service pages) -->
          <TrustStack variant={heroImage ? 'compact' : 'default'} className="justify-start" />
        </div>
        {heroImage && (
          <div class="hidden lg:block">
            <img src={heroImage} alt={heroImageAlt || heroTitle} class="rounded-2xl shadow-2xl w-full object-cover max-h-[450px]" loading="eager" />
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Page Content -->
  <slot />

  <CTASection />
</Layout>
