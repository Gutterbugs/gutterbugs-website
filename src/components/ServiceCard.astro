---
interface Props {
  icon: string;
  title: string;
  description: string;
  href: string;
  price?: string;
}

const { icon, title, description, href, price } = Astro.props;
---

<div class="bg-gray-50 rounded-2xl p-6 hover:bg-gray-750 border border-gray-200 hover:border-sky-500/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-sky-500/10 group">
  <div class="w-12 h-12 bg-sky-500/10 rounded-xl flex items-center justify-center text-2xl mb-5 group-hover:bg-sky-500/20 transition-colors duration-300">
    {icon}
  </div>
  <h3 class="text-gray-900 font-bold text-lg mb-3" style="font-family: 'Poppins', sans-serif;">{title}</h3>
  <p class="text-gray-500 text-sm leading-relaxed mb-4">{description}</p>
  {price && (
    <p class="text-sky-400 text-sm font-semibold mb-4">From {price}</p>
  )}
  <a href={href} class="inline-flex items-center text-sky-400 hover:text-sky-300 text-sm font-semibold transition-colors duration-200 group-hover:gap-2 gap-1">
    Learn More
    <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
  </a>
</div>
