---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';

const photos = [
  { src: '/photos/gutter-before.jpg', label: 'Gutter Before Clearing', service: 'Gutter Clearing' },
  { src: '/photos/gutter-after.jpg', label: 'Gutter After Clearing', service: 'Gutter Clearing' },
  { src: '/photos/roof-cleaning-side-by-side.jpg', label: 'Roof Cleaning Before & After', service: 'Roof Cleaning' },
  { src: '/photos/roof-cleaning-after-photo.jpg', label: 'Roof After Cleaning', service: 'Roof Cleaning' },
  { src: '/photos/roof-cleaning-pressure-wash.webp', label: 'Roof Pressure Washing', service: 'Roof Cleaning' },
  { src: '/photos/block-paving-pressure-washing.jpg', label: 'Block Paving Pressure Wash', service: 'Pressure Washing' },
  { src: '/photos/patio-cleaning.jpg', label: 'Patio Cleaning', service: 'Pressure Washing' },
  { src: '/photos/patio-cleaning-2.jpg', label: 'Patio Cleaning Result', service: 'Pressure Washing' },
  { src: '/photos/conservatory-roof-before-and-after.jpg', label: 'Conservatory Roof Before & After', service: 'Conservatory Cleaning' },
  { src: '/photos/soffit-fascia-washing.webp', label: 'Soffit & Fascia Washing', service: 'Soffit & Fascia' },
];
---

<Layout
  title="Before & After Gallery | Gutterbugs"
  description="See the results of our professional exterior cleaning services. Before and after photos from gutter clearing, roof cleaning and pressure washing jobs."
>
  <!-- Hero -->
  <section class="bg-white pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-sky-900/20 to-transparent pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <div class="inline-flex items-center gap-2 bg-sky-500/10 border border-sky-500/30 rounded-full px-4 py-1.5 mb-6">
        <span class="text-sky-400 text-sm font-medium">Our Work</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4" style="font-family: 'Poppins', sans-serif;">
        Before & After Gallery
      </h1>
      <p class="text-xl text-gray-600 max-w-xl mx-auto">
        Real results from real jobs. See the transformations we achieve for our customers.
      </p>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {photos.map(photo => (
          <div class="relative rounded-2xl overflow-hidden border border-gray-200 hover:border-sky-500/30 transition-all duration-300 hover:scale-[1.02] group">
            <img
              src={photo.src}
              alt={photo.label}
              class="w-full aspect-[4/3] object-cover"
              loading="lazy"
            />
            <!-- Service tag -->
            <div class="absolute bottom-3 left-3">
              <span class="bg-black/60 backdrop-blur-sm text-white text-xs px-3 py-1.5 rounded-full font-medium">
                {photo.service}
              </span>
            </div>
            <!-- Label on hover -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
              <p class="text-white text-sm font-medium p-4">{photo.label}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center">
        <p class="text-gray-500 text-sm mb-6">We add new photos regularly. Want to see what we can do for your property?</p>
        <a href="/contact" class="inline-flex items-center justify-center bg-sky-500 hover:bg-sky-600 text-white px-8 py-4 rounded-full font-semibold text-lg transition-all duration-200 shadow-lg shadow-sky-500/25">
          Get Your Free Quote →
        </a>
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
