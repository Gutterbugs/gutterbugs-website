---
const services = [
  { value: 'gutter_cleaning', label: 'Gutter Cleaning' },
  { value: 'roof_scraping', label: 'Roof Moss Removal (Scraping)' },
  { value: 'roof_pressure', label: 'Roof Pressure Washing' },
  { value: 'driveway', label: 'Driveway/Patio Cleaning' },
  { value: 'soffit_fascia', label: 'Soffit & Fascia Washing' },
  { value: 'conservatory_roof', label: 'Conservatory Roof Washing' },
  { value: 'solar_panels', label: 'Solar Panel Washing' },
  { value: 'other', label: 'Other Services' },
];
---

<form id="contact-form" class="space-y-6">
  <!-- Hidden attribution fields -->
  <input type="hidden" name="gclid" id="gclid" />
  <input type="hidden" name="source" id="source" />
  <input type="hidden" name="landing_page" id="landing_page" />
  <input type="hidden" name="referrer" id="referrer" />
  <input type="hidden" name="utm_source" id="utm_source" />
  <input type="hidden" name="utm_medium" id="utm_medium" />
  <input type="hidden" name="utm_campaign" id="utm_campaign" />
  <input type="hidden" name="utm_term" id="utm_term" />

  <!-- Name -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="first_name" class="block text-sm font-medium text-gray-700 mb-1.5">First Name <span class="text-red-500">*</span></label>
      <input
        type="text"
        id="first_name"
        name="first_name"
        required
        class="w-full bg-white border-2 border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-colors duration-200"
      />
    </div>
    <div>
      <label for="last_name" class="block text-sm font-medium text-gray-700 mb-1.5">Last Name <span class="text-red-500">*</span></label>
      <input
        type="text"
        id="last_name"
        name="last_name"
        required
        class="w-full bg-white border-2 border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-colors duration-200"
      />
    </div>
  </div>

  <!-- Email & Phone -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email <span class="text-red-500">*</span></label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full bg-white border-2 border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-colors duration-200"
      />
    </div>
    <div>
      <label for="phone" class="block text-sm font-medium text-gray-700 mb-1.5">Phone <span class="text-red-500">*</span></label>
      <input
        type="tel"
        id="phone"
        name="phone"
        required
        class="w-full bg-white border-2 border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-colors duration-200"
      />
    </div>
  </div>

  <!-- Address (Google Places Autocomplete) -->
  <div class="relative">
    <label for="address" class="block text-sm font-medium text-gray-700 mb-1.5">Property Address <span class="text-red-500">*</span></label>
    <input
      type="text"
      id="address"
      name="address"
      required
      placeholder="Start typing your address..."
      autocomplete="off"
      class="w-full bg-white border-2 border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-colors duration-200"
    />
    <input type="hidden" id="address_city" name="address_city" />
    <input type="hidden" id="address_county" name="address_county" />
    <input type="hidden" id="address_lat" name="address_lat" />
    <input type="hidden" id="address_lng" name="address_lng" />
  </div>

  <!-- Postcode (auto-filled by autocomplete, still editable) -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="postcode" class="block text-sm font-medium text-gray-700 mb-1.5">Postcode</label>
      <input
        type="text"
        id="postcode"
        name="postcode"
        placeholder="e.g. HP23 4AB"
        class="w-full bg-white border-2 border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-colors duration-200"
      />
    </div>
  </div>

  <!-- Services Checkboxes -->
  <div>
    <label class="block text-sm font-medium text-gray-700 mb-3">Services Needed</label>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {services.map(s => (
        <label class="flex items-center gap-3 cursor-pointer group">
          <input
            type="checkbox"
            name="services"
            value={s.value}
            class="w-5 h-5 rounded border-2 border-gray-300 text-sky-500 focus:ring-sky-500 focus:ring-offset-0 accent-sky-500 flex-shrink-0"
          />
          <span class="text-gray-700 text-sm group-hover:text-sky-600 transition-colors">{s.label}</span>
        </label>
      ))}
    </div>
  </div>

  <!-- Message -->
  <div>
    <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">Additional Details</label>
    <textarea
      id="form-message"
      name="message"
      rows="4"
      placeholder="Tell us about your property, any specific requirements, or questions you have..."
      class="w-full bg-white border-2 border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-colors duration-200 resize-none"
    ></textarea>
  </div>

  <!-- Success message -->
  <div id="form-success" class="hidden bg-sky-50 border border-sky-200 text-sky-800 text-sm px-4 py-3 rounded-xl text-center font-medium">
    Thank you! Your request has been submitted. We'll get back to you with a quote shortly.
  </div>

  <!-- Error message -->
  <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-xl text-center">
    Something went wrong. Please try again or call us on <a href="tel:07904621160" class="underline font-medium">07904621160</a>.
  </div>

  <button
    type="submit"
    id="submit-btn"
    class="w-full bg-sky-500 hover:bg-sky-600 text-white py-4 rounded-full font-semibold text-lg transition-all duration-200 shadow-lg shadow-sky-500/25 hover:shadow-sky-500/40 hover:-translate-y-0.5 disabled:opacity-70 disabled:cursor-not-allowed disabled:hover:translate-y-0"
  >
    <span id="submit-text">Get My Free Quote</span>
    <span id="submit-loading" class="hidden">Submitting...</span>
  </button>

  <p class="text-gray-500 text-xs text-center">
    We respond within 24 hours. Your details are kept confidential.
  </p>
</form>

<script>
  // ─── Attribution Capture ────────────────────────────────────────────
  function getUrlParam(name: string): string | null {
    return new URLSearchParams(window.location.search).get(name);
  }

  function initAttribution() {
    // gclid: capture from URL, persist in localStorage
    const gclidParam = getUrlParam('gclid');
    if (gclidParam) localStorage.setItem('gclid', gclidParam);
    const gclid = gclidParam || localStorage.getItem('gclid') || '';
    (document.getElementById('gclid') as HTMLInputElement).value = gclid;

    // UTM parameters
    ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term'].forEach(param => {
      const val = getUrlParam(param);
      if (val) (document.getElementById(param) as HTMLInputElement).value = val;
    });

    // Referrer & landing page
    (document.getElementById('referrer') as HTMLInputElement).value = document.referrer || '';
    (document.getElementById('landing_page') as HTMLInputElement).value = window.location.href;

    // Source determination
    let source = 'direct';
    if (gclid) source = 'google_ads';
    else if (getUrlParam('utm_source')) source = getUrlParam('utm_source')!;
    else if (document.referrer && !document.referrer.includes('gutterbugs.co.uk')) source = 'organic';
    (document.getElementById('source') as HTMLInputElement).value = source;

    // Store gclid for future visits
    if (gclid) localStorage.setItem('gclid', gclid);
  }

  // ─── Form Submission ────────────────────────────────────────────────
  function initForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const submitText = document.getElementById('submit-text')!;
    const submitLoading = document.getElementById('submit-loading')!;
    const errorDiv = document.getElementById('form-error')!;
    const successDiv = document.getElementById('form-success')!;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      submitBtn.disabled = true;
      submitText.classList.add('hidden');
      submitLoading.classList.remove('hidden');
      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');

      // Collect form data
      const formData = new FormData(form);
      const data: Record<string, string | null> = {};
      formData.forEach((value, key) => {
        if (key !== 'services') data[key] = value.toString();
      });

      // Handle multiple service checkboxes → comma-separated string
      const checkedServices = Array.from(
        form.querySelectorAll('input[name="services"]:checked')
      ).map((cb) => (cb as HTMLInputElement).value);
      data.service_type = checkedServices.length > 0 ? checkedServices.join(',') : null;

      // GA4 conversion event
      if (typeof gtag !== 'undefined') {
        gtag('event', 'Contact_Us_Form_Entry', {
          event_category: 'form',
          event_label: data.service_type || 'unspecified',
        });
      }

      // Phone call click tracking (for attribution)
      if (typeof gtag !== 'undefined') {
        gtag('event', 'generate_lead', {
          currency: 'GBP',
          value: 0,
        });
      }

      try {
        const endpoint = (import.meta as any).env?.PUBLIC_FORM_ENDPOINT || 'https://gutterbugs-form.ryan-1f9.workers.dev';
        const response = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const result = await response.json();

        if (response.ok) {
          // Show success inline or redirect to thank-you
          successDiv.classList.remove('hidden');
          form.reset();
          
          // Redirect after short delay so user sees success message
          setTimeout(() => {
            window.location.href = '/thank-you';
          }, 1500);
        } else {
          throw new Error(result.error || 'Server error');
        }
      } catch {
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitText.classList.remove('hidden');
        submitLoading.classList.add('hidden');
      }
    });
  }

  // Declare gtag for TypeScript
  declare function gtag(...args: any[]): void;
  declare const google: any;

  // ─── Address Autocomplete (Google Places API New) ─────────────────────
  let _autocompleteTimeout: ReturnType<typeof setTimeout> | null = null;
  let _autocompleteResults: any[] = [];
  let _selectedIndex = -1;

  function initAddressAutocomplete() {
    const addressInput = document.getElementById('address') as HTMLInputElement;
    if (!addressInput) return;

    const apiKey = (document.querySelector('meta[name="google-places-key"]') as HTMLMetaElement)?.content;
    if (!apiKey) return;

    // Create dropdown container
    const dropdown = document.createElement('div');
    dropdown.id = 'address-dropdown';
    dropdown.className = 'absolute left-0 right-0 top-full mt-1 bg-white border-2 border-gray-200 rounded-xl shadow-lg z-50 overflow-hidden hidden';
    addressInput.parentElement!.appendChild(dropdown);

    // Fetch autocomplete suggestions from Places API (New)
    async function fetchSuggestions(query: string) {
      if (query.length < 3) { hideDropdown(); return; }

      try {
        const response = await fetch('https://places.googleapis.com/v1/places:autocomplete', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Goog-Api-Key': apiKey,
          },
          body: JSON.stringify({
            input: query,
            includedRegionCodes: ['gb'],
            includedPrimaryTypes: ['street_address', 'subpremise', 'premise'],
            languageCode: 'en-GB',
          }),
        });

        if (!response.ok) return;
        const data = await response.json();
        _autocompleteResults = data.suggestions || [];
        renderDropdown();
      } catch (e) {
        // Silently fail — field works as plain text
      }
    }

    // Fetch full place details
    async function fetchPlaceDetails(placeId: string) {
      try {
        const response = await fetch(`https://places.googleapis.com/v1/places/${placeId}`, {
          headers: {
            'X-Goog-Api-Key': apiKey,
            'X-Goog-FieldMask': 'addressComponents,location,formattedAddress,shortFormattedAddress',
          },
        });

        if (!response.ok) return null;
        return response.json();
      } catch (e) {
        return null;
      }
    }

    function renderDropdown() {
      if (_autocompleteResults.length === 0) { hideDropdown(); return; }

      dropdown.innerHTML = _autocompleteResults.map((suggestion, i) => {
        const place = suggestion.placePrediction;
        if (!place) return '';
        const main = place.structuredFormat?.mainText?.text || '';
        const secondary = place.structuredFormat?.secondaryText?.text || '';
        return `<div class="address-option px-4 py-3 cursor-pointer hover:bg-sky-50 text-sm border-t border-gray-100 first:border-t-0 transition-colors" data-index="${i}">
          <span class="font-semibold text-gray-900">${main}</span>
          <span class="text-gray-500"> ${secondary}</span>
        </div>`;
      }).join('');

      dropdown.classList.remove('hidden');
      _selectedIndex = -1;

      // Click handlers
      dropdown.querySelectorAll('.address-option').forEach(option => {
        option.addEventListener('click', () => {
          const idx = parseInt((option as HTMLElement).dataset.index || '0');
          selectSuggestion(idx);
        });
      });
    }

    function hideDropdown() {
      dropdown.classList.add('hidden');
      _autocompleteResults = [];
      _selectedIndex = -1;
    }

    async function selectSuggestion(index: number) {
      const suggestion = _autocompleteResults[index];
      if (!suggestion?.placePrediction) return;

      const placeId = suggestion.placePrediction.placeId;
      hideDropdown();

      // Show the formatted text immediately
      const mainText = suggestion.placePrediction.structuredFormat?.mainText?.text || '';
      addressInput.value = mainText;

      // Fetch full details for structured data
      const details = await fetchPlaceDetails(placeId);
      if (!details) return;

      // Extract components
      let streetNumber = '';
      let route = '';
      let city = '';
      let county = '';
      let postcode = '';

      for (const component of (details.addressComponents || [])) {
        const types = component.types || [];
        if (types.includes('street_number')) streetNumber = component.longText || '';
        if (types.includes('route')) route = component.longText || '';
        if (types.includes('postal_town')) city = component.longText || '';
        if (types.includes('locality') && !city) city = component.longText || '';
        if (types.includes('administrative_area_level_2')) county = component.longText || '';
        if (types.includes('postal_code')) postcode = component.longText || '';
      }

      // Set clean street address
      const streetAddress = streetNumber ? `${streetNumber} ${route}` : route;
      addressInput.value = streetAddress || details.shortFormattedAddress || mainText;

      // Auto-fill postcode
      const postcodeInput = document.getElementById('postcode') as HTMLInputElement;
      if (postcodeInput && postcode) postcodeInput.value = postcode;

      // Fill hidden fields
      const cityInput = document.getElementById('address_city') as HTMLInputElement;
      const countyInput = document.getElementById('address_county') as HTMLInputElement;
      const latInput = document.getElementById('address_lat') as HTMLInputElement;
      const lngInput = document.getElementById('address_lng') as HTMLInputElement;

      if (cityInput) cityInput.value = city;
      if (countyInput) countyInput.value = county;

      if (details.location) {
        if (latInput) latInput.value = String(details.location.latitude || '');
        if (lngInput) lngInput.value = String(details.location.longitude || '');
      }
    }

    // Input event — debounced autocomplete
    addressInput.addEventListener('input', () => {
      if (_autocompleteTimeout) clearTimeout(_autocompleteTimeout);
      _autocompleteTimeout = setTimeout(() => {
        fetchSuggestions(addressInput.value);
      }, 300);
    });

    // Keyboard navigation
    addressInput.addEventListener('keydown', (e: KeyboardEvent) => {
      const options = dropdown.querySelectorAll('.address-option');
      if (options.length === 0) return;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        _selectedIndex = Math.min(_selectedIndex + 1, options.length - 1);
        options.forEach((o, i) => o.classList.toggle('bg-sky-50', i === _selectedIndex));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        _selectedIndex = Math.max(_selectedIndex - 1, 0);
        options.forEach((o, i) => o.classList.toggle('bg-sky-50', i === _selectedIndex));
      } else if (e.key === 'Enter' && _selectedIndex >= 0) {
        e.preventDefault();
        selectSuggestion(_selectedIndex);
      } else if (e.key === 'Escape') {
        hideDropdown();
      }
    });

    // Close dropdown on click outside
    document.addEventListener('click', (e) => {
      if (!addressInput.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
        hideDropdown();
      }
    });

    // Close on blur (with delay for click to register)
    addressInput.addEventListener('blur', () => {
      setTimeout(hideDropdown, 200);
    });
  }

  initAttribution();
  initForm();
  initAddressAutocomplete();
</script>
