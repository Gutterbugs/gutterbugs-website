---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import CTASection from '../../components/CTASection.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { locations, serviceTypes } from '../../lib/locations';

export function getStaticPaths() {
  const paths = [];
  for (const service of serviceTypes) {
    for (const location of locations) {
      paths.push({
        params: { service: service.slug, location: location.slug },
        props: { service, location },
      });
    }
  }
  return paths;
}

const { service, location } = Astro.props;

const title = `${service.name} in ${location.name} | Gutterbugs`;
const description = `Professional ${service.name.toLowerCase()} in ${location.name}, ${location.county}. Family-run, 5-star rated, 3000+ homes cleaned. Free quotes — call 07904621160.`;
const heroSubtitle = `Professional ${service.name.toLowerCase()} in ${location.name}. Family-run, 5-star rated, 3000+ homes cleaned. Free quotes — call 07904621160.`;

const faqs = [
  { question: `How much does ${service.name.toLowerCase()} cost in ${location.name}?`, answer: `Prices vary based on property size and access requirements. We provide free, no-obligation quotes for all ${location.name} properties. Call 07904621160 or use our contact form for a quick quote.` },
  { question: `How quickly can you get to ${location.name}?`, answer: `We're based in Tring, so ${location.name} is well within our regular service area. We can often provide same-day or next-day quotes, and schedule work within the week.` },
  { question: `Do you serve areas near ${location.name}?`, answer: `Yes! We cover ${location.nearbyAreas.join(', ')} and all surrounding areas. If you're not sure whether we cover your location, just give us a call.` },
  { question: `Are you insured for ${service.name.toLowerCase()} work?`, answer: `Absolutely. We carry full public liability insurance for all our exterior cleaning services. Your property is in safe hands.` },
];

const schemaData = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `${service.name} in ${location.name}`,
  "provider": {
    "@type": "LocalBusiness",
    "name": "Gutterbugs",
    "telephone": "07904621160",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Pegasus Barn, Astrope Lane",
      "addressLocality": "Tring",
      "postalCode": "HP23 4PP",
      "addressCountry": "GB"
    }
  },
  "areaServed": {
    "@type": "Place",
    "name": `${location.name}, ${location.county}`
  },
  "description": description
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <Hero
    title={`${service.name} in ${location.name}`}
    subtitle={heroSubtitle}
  />

  <!-- Service Description -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none">
        <h2 class="text-2xl font-bold text-gray-900 mb-4" style="font-family: 'Poppins', sans-serif;">
          Professional {service.name} in {location.name}
        </h2>
        <p class="text-gray-700 leading-relaxed mb-6">
          {location.description}
        </p>
        <p class="text-gray-700 leading-relaxed mb-6">
          {service.shortDescription}
        </p>
        <p class="text-gray-700 leading-relaxed">
          We've cleaned over 3,000 homes and counting. As a family-run business, we take pride in every job — from a simple gutter clear on a terraced house to a full roof restoration on a large detached property.
        </p>
      </div>
    </div>
  </section>

  <!-- Why Choose Us for This Area -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-8" style="font-family: 'Poppins', sans-serif;">
        Why Choose Gutterbugs in {location.name}?
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-sky-100 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="text-sky-600 text-lg">📍</span>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">Local to {location.name}</h3>
            <p class="text-gray-600 text-sm">Based in Tring, we're right on your doorstep. Quick response times and local knowledge.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-sky-100 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="text-sky-600 text-lg">⭐</span>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">5-Star Rated</h3>
            <p class="text-gray-600 text-sm">92 five-star Google reviews from happy customers.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-sky-100 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="text-sky-600 text-lg">👨‍👦</span>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">Family Business</h3>
            <p class="text-gray-600 text-sm">Ryan and Richard — father and son team. We treat your property like our own.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-sky-100 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="text-sky-600 text-lg">📸</span>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">Before & After Photos</h3>
            <p class="text-gray-600 text-sm">We photograph every job so you can see exactly what we've done.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Areas We Cover -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-4" style="font-family: 'Poppins', sans-serif;">
        Areas We Cover Near {location.name}
      </h2>
      <p class="text-gray-700 mb-6">
        We serve {location.name} and all surrounding areas including:
      </p>
      <div class="flex flex-wrap gap-2 mb-6">
        {location.nearbyAreas.map(area => (
          <span class="bg-gray-100 text-gray-700 px-3 py-1.5 rounded-full text-sm font-medium">{area}</span>
        ))}
      </div>
      <p class="text-gray-600 text-sm">
        Postcodes served: {location.postcodesServed.join(', ')}. Not sure if we cover your area? <a href="/contact" class="text-sky-600 hover:text-sky-700 font-medium">Get in touch</a> — we're happy to help.
      </p>
    </div>
  </section>

  <!-- Other Services in This Area -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6" style="font-family: 'Poppins', sans-serif;">
        Our Services in {location.name}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {serviceTypes.map(s => (
          <a
            href={s.slug === service.slug ? `/${s.slug}` : `/locations/${s.slug}-${location.slug}`}
            class:list={[
              "block p-4 rounded-xl border transition-all duration-200",
              s.slug === service.slug
                ? "bg-sky-50 border-sky-200 text-sky-700"
                : "bg-white border-gray-200 text-gray-700 hover:border-sky-200 hover:bg-sky-50"
            ]}
          >
            <p class="font-semibold text-sm">{s.name}</p>
            {s.slug === service.slug && <span class="text-xs text-sky-500">Currently viewing</span>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-8" style="font-family: 'Poppins', sans-serif;">
        Frequently Asked Questions — {service.name} in {location.name}
      </h2>
      <FAQAccordion faqs={faqs} />
    </div>
  </section>

  <CTASection
    title={`Need ${service.name.toLowerCase()} in ${location.name}?`}
    subtitle={`Get a free, no-obligation quote today. We're local, we're reliable, and we're ready to help.`}
  />
</Layout>
