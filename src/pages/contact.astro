---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout
  title="Contact Gutterbugs | Get a Free Quote in Hertfordshire"
  description="Contact Gutterbugs for a free, no-obligation quote. Gutter clearing, roof cleaning and exterior cleaning across Hertfordshire. Call 07904621160 or fill in our form."
>
  <!-- Hero -->
  <section class="bg-white pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-sky-900/20 to-transparent pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <div class="inline-flex items-center gap-2 bg-sky-500/10 border border-sky-500/30 rounded-full px-4 py-1.5 mb-6">
        <span class="text-sky-400 text-sm font-medium">Free No-Obligation Quote</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4" style="font-family: 'Poppins', sans-serif;">
        Get in Touch
      </h1>
      <p class="text-xl text-gray-600 max-w-xl mx-auto">
        Fill in the form below and we will get back to you within 24 hours with a free, no-obligation quote.
      </p>
    </div>
  </section>

  <!-- Form + Contact Info -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Form -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl p-8 border border-gray-200">
            <h2 class="text-2xl font-bold text-gray-900 mb-6" style="font-family: 'Poppins', sans-serif;">Request a Free Quote</h2>
            <ContactForm />
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <!-- Contact Details -->
          <div class="bg-white rounded-2xl p-6 border border-gray-200">
            <h3 class="text-gray-900 font-bold mb-5" style="font-family: 'Poppins', sans-serif;">Contact Details</h3>
            <ul class="space-y-4">
              <li>
                <a href="tel:07904621160" class="flex items-start gap-3 group">
                  <span class="text-sky-500 text-xl mt-0.5">📞</span>
                  <div>
                    <p class="text-gray-500 text-xs mb-0.5">Phone</p>
                    <p class="text-gray-900 font-semibold group-hover:text-sky-400 transition-colors">07904621160</p>
                  </div>
                </a>
              </li>
              <li>
                <a href="mailto:ryan@gutterbugs.co.uk" class="flex items-start gap-3 group">
                  <span class="text-sky-500 text-xl mt-0.5">✉️</span>
                  <div>
                    <p class="text-gray-500 text-xs mb-0.5">Email</p>
                    <p class="text-gray-900 font-semibold text-sm group-hover:text-sky-400 transition-colors">ryan@gutterbugs.co.uk</p>
                  </div>
                </a>
              </li>
              <li>
                <div class="flex items-start gap-3">
                  <span class="text-sky-500 text-xl mt-0.5">📍</span>
                  <div>
                    <p class="text-gray-500 text-xs mb-0.5">Address</p>
                    <p class="text-gray-900 text-sm">Pegasus Barn, Astrope Lane<br />Tring, HP23 4PP</p>
                  </div>
                </div>
              </li>
              <li>
                <div class="flex items-start gap-3">
                  <span class="text-sky-500 text-xl mt-0.5">🕐</span>
                  <div>
                    <p class="text-gray-500 text-xs mb-0.5">Hours</p>
                    <p class="text-gray-900 text-sm">Monday – Friday<br />9:00am – 5:00pm</p>
                  </div>
                </div>
              </li>
            </ul>
          </div>

          <!-- Quick Promise -->
          <div class="bg-white rounded-2xl p-6 border border-gray-200">
            <h3 class="text-gray-900 font-bold mb-4" style="font-family: 'Poppins', sans-serif;">Our Promise</h3>
            <ul class="space-y-3">
              {[
                'Free, no-obligation quotes',
                'Response within 24 hours',
                'Transparent, honest pricing',
                'Satisfaction guaranteed',
              ].map(item => (
                <li class="flex items-center gap-2 text-sm text-gray-600">
                  <span class="text-sky-400 font-bold">✓</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Map Placeholder -->
          <div class="bg-gray-50 rounded-2xl border border-gray-200 overflow-hidden">
            <div class="h-40 bg-gradient-to-br from-gray-700 to-gray-800 flex items-center justify-center">
              <div class="text-center">
                <span class="text-4xl mb-2 block">🗺️</span>
                <p class="text-gray-500 text-sm">Service area map coming soon</p>
                <p class="text-gray-500 text-xs mt-1">Tring & Surrounding Areas</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
