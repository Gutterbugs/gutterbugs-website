---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Thank You | Gutterbugs"
  description="Thank you for contacting Gutterbugs. We will be in touch within 24 hours with your free quote."
>
  <section class="min-h-screen bg-white flex items-center justify-center px-4 pt-16">
    <div class="max-w-lg mx-auto text-center py-20">
      <!-- Success Icon -->
      <div class="w-24 h-24 bg-sky-500/20 rounded-full flex items-center justify-center mx-auto mb-8 border border-sky-500/30">
        <span class="text-5xl">✅</span>
      </div>

      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4" style="font-family: 'Poppins', sans-serif;">
        Thank You!
      </h1>

      <p class="text-xl text-gray-600 mb-4">
        We have received your enquiry and will be in touch within 24 hours.
      </p>

      <p class="text-gray-500 mb-10">
        If you need to speak to us urgently, please call us on{' '}
        <a href="tel:07904621160" class="text-sky-400 hover:text-sky-300 font-semibold transition-colors">07904621160</a>.
      </p>

      <!-- What Happens Next -->
      <div class="bg-white rounded-2xl p-6 border border-gray-200 text-left mb-10">
        <h2 class="text-gray-900 font-bold text-lg mb-4 text-center" style="font-family: 'Poppins', sans-serif;">What happens next?</h2>
        <ul class="space-y-3">
          {[
            { step: '1', text: 'We review your enquiry and check our availability' },
            { step: '2', text: 'We contact you within 24 hours with a free, tailored quote' },
            { step: '3', text: 'Once you are happy, we schedule a convenient appointment' },
            { step: '4', text: 'We arrive on time, do a great job, and you are delighted!' },
          ].map(item => (
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 bg-sky-500 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0 mt-0.5">
                {item.step}
              </span>
              <span class="text-gray-600 text-sm">{item.text}</span>
            </li>
          ))}
        </ul>
      </div>

      <a
        href="/"
        class="inline-flex items-center justify-center bg-sky-500 hover:bg-sky-600 text-white px-8 py-4 rounded-full font-semibold text-lg transition-all duration-200 shadow-lg shadow-sky-500/25"
      >
        ← Back to Homepage
      </a>
    </div>
  </section>
</Layout>

<!-- GA4 Conversion Events -->
<script is:inline>
  if (typeof window !== 'undefined' && typeof gtag === 'function') {
    // Primary conversion event (matches Google Ads import)
    gtag('event', 'Contact_Us_Form_Entry', {
      event_category: 'form',
      event_label: 'contact_form_submission',
    });
    // Lead generation event
    gtag('event', 'generate_lead', {
      currency: 'GBP',
      value: 0,
    });
  }
</script>
